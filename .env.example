# --- Backend ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# API key the runner uses to authenticate with the backend
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
LLMEVAL_API_KEY=generate-a-random-string-here

# --- Runner ---
# Judge model API key (used by RAGAS for scoring)
OPENAI_API_KEY=sk-...

# URL of the backend (local or deployed)
LLMEVAL_API_URL=http://localhost:8000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=same-as-llmeval-api-key
